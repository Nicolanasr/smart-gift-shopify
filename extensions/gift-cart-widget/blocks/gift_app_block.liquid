{%- assign current_product_price = product.selected_or_first_available_variant.price | default: 0 -%}
<div class="gift-widget-container" 
     data-product-price="{{ current_product_price }}"
     data-product-title="{{ product.title | escape }}"
     data-shop="{{ shop.permanent_domain }}">
  <div class="gift-widget-card">
    <!-- Header with Toggle -->
    <div class="gift-widget-header">
      <div class="gift-widget-title-group">
        <p class="gift-title">
          Make this a gift (<span id="gift-price-display"> -- </span>)
        </p>
      </div>
      <label class="gift-toggle-switch">
        <input type="checkbox" id="gift-toggle-input"> <span class="gift-slider"></span>
      </label>
    </div>

    {%- if block.settings.enable_caption == true -%}
    {%- assign show_caption = true -%}
    {%- else -%}
    {%- assign show_caption = false -%}
    {%- endif -%}

    {%- if block.settings.enable_message == true -%}
    {%- assign show_message = true -%}
    {%- else -%}
    {%- assign show_message = false -%}
    {%- endif -%}

    <!-- Main Content Area (Hidden by default) -->
    <div id="gift-options-content" class="gift-options-content" style="display: none;">
      
      {% if block.settings.enable_digital == true or block.settings.enable_printed == true %}
      <div class ="flex " style="justify-content:space-between;">
        <!-- Optional Message Checkbox (Global) -->
        <div class="gift-input-group" style="margin-bottom: 0.75rem;">
            {% if block.settings.enable_message == true %}
            <label style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; color: #374151;">
                <input type="checkbox" id="gift-add-message-checkbox" checked>
                {{ block.settings.custom_message_label | default: 'Add custom message' }}
            </label>
            {% endif %}
        </div>
        <!-- Total Price Display -->
        <div class="gift-total-row">
            Total: <span id="gift-total-display" class="gift-total-amount"> -- </span>
        </div>

      </div>

      <!-- Tabs -->
      <div id="gift-tabs-container" class="gift-tabs">
        {% if block.settings.enable_digital == true %}
        <button type="button" class="gift-tab" data-tab="digital" title="A QR code will be generated and attached to the order">
          Digital
        </button>
        {% endif %}
        {% if block.settings.enable_printed == true %}
        <button type="button" class="gift-tab" data-tab="printed" title="Your request will be printed">
          Printed Card
        </button>
        {% endif %}
      </div>

      <!-- Digital Options -->
      {% if block.settings.enable_digital == true %}
      <div id="tab-content-digital" class="tab-content" style="display: none;">

        <div id="digital-options-container">
            <div class="gift-format-label">Choose digital format</div>
            <!-- Order: Video -> Photo -> URL -> Audio -> Text -->
            <div class="gift-format-buttons">
            <button type="button" class="format-btn active" data-format="video">
                Video
            </button>
            <button type="button" class="format-btn" data-format="photo">
                Photo
            </button>
            <button type="button" class="format-btn" data-format="url">
                URL
            </button>
            <button type="button" class="format-btn" data-format="audio">
                Audio
            </button>
            <button type="button" class="format-btn" data-format="text">
                Text
            </button>
            </div>

            <!-- Dynamic Content based on format -->
            <div id="format-video-content" class="format-specific-content">
            <button type="button" id="record-video-btn" class="action-btn" onclick="document.getElementById('gift-video-file').click()">
                <span class="record-icon">●</span> Record Video Message
            </button>
            <input type="file" id="gift-video-file" accept="video/*" class="gift-file-input" style="display: none;" onchange="handleFileSelect(this)" data-max-size="104857600">
            <span class="gift-file-feedback" id="video-file-feedback"></span>
            </div>

            <div id="format-photo-content" class="format-specific-content" style="display: none;">
            <button type="button" class="action-btn" onclick="document.getElementById('gift-photo-file').click()">
                Take Photo
            </button>
            <input type="file" id="gift-photo-file" accept="image/*" class="gift-file-input" style="display: none;" onchange="handleFileSelect(this)" data-max-size="10485760">
            <span class="gift-file-feedback" id="photo-file-feedback"></span>
            </div>

            <div id="format-url-content" class="format-specific-content" style="display: none;">
            <input type="url" id="gift-url-input" class="gift-text-input" placeholder="https://example.com/your-special-link">
            </div>
            
            <div id="format-audio-content" class="format-specific-content" style="display: none;">
            <!-- Action Button triggers hidden input -->
            <button type="button" class="action-btn" onclick="document.getElementById('gift-audio-file').click()">
                Upload Audio 
            </button>
            <input type="file" id="gift-audio-file" accept="audio/*" class="gift-file-input" style="display: none;" onchange="handleFileSelect(this)" data-max-size="20971520">
            <span class="gift-file-feedback" id="audio-file-feedback"></span>
            </div>

            <div id="format-text-content" class="format-specific-content" style="display: none;">
            <textarea id="gift-digital-message" class="gift-textarea" placeholder="Write your digital message..." maxlength="300"></textarea>
            <div class="gift-char-count"><span id="digital-msg-count">0</span>/300</div>
            </div>

            <!-- Digital Caption (Shared) -->
            {% if show_caption %}
            <div id="digital-caption-wrapper" style="margin-top: 10px; display: none;">
              <label for="gift-digital-caption" class="gift-input-label">{{ block.settings.caption_label | default: 'Caption (appears under QR code)' }}</label>
              <input type="text" id="gift-digital-caption" class="gift-text-input" placeholder="{{ block.settings.caption_placeholder | default: 'Short message...' }}" maxlength="50">
              <div class="gift-char-count"><span id="digital-caption-count">0</span>/50</div>
            </div>
            {% endif %}
        </div>
      </div>
      {% endif %}

      <!-- Printed Options -->
      {% if block.settings.enable_printed == true %}
      <div id="tab-content-printed" class="tab-content" style="display: none;">
        
        <div id="printed-options-container">
            <!-- Printed Format Selection (Styled like Format Buttons) -->
            <div class="gift-format-buttons">
                <button type="button" class="format-btn active printed-format-btn" data-format="text_msg">
                Message
                </button>
                <button type="button" class="format-btn printed-format-btn" data-format="printed_photo">
                Photo
                </button>
            </div>
            
            <div id="printed-message-container">
            <label for="gift-message-text" class="sr-only">Message</label>
            <textarea id="gift-message-text" class="gift-textarea" placeholder="Write your message here..." maxlength="300"></textarea>
            <div class="gift-char-count"><span id="printed-msg-count">0</span>/300</div>
            </div>

            <div id="printed-photo-container" style="display: none;">
            <button type="button" class="action-btn" onclick="document.getElementById('gift-printed-photo-file').click()">
                Upload Photo for Printing
            </button>
            <input type="file" id="gift-printed-photo-file" accept="image/*" class="gift-file-input" style="display: none;" onchange="handleFileSelect(this)" data-max-size="10485760">
            <span class="gift-file-feedback" id="printed-photo-file-feedback"></span>
            
            <!-- Printed Photo Caption (Only for Photo) -->
            {% if show_caption %}
            <div id="printed-caption-wrapper" style="margin-top: 10px; display: none;">
                <label for="gift-printed-caption" class="gift-input-label">{{ block.settings.caption_label | default: 'Caption (printed under photo)' }}</label>
                <input type="text" id="gift-printed-caption" class="gift-text-input" placeholder="{{ block.settings.caption_placeholder | default: 'Message printed under the photo' }}" maxlength="50">
                <div class="gift-char-count"><span id="printed-caption-count">0</span>/50</div>
            </div>
            {% endif %}
            </div>
        </div>
      </div>
      {% endif %}
      {% endif %}


      <div class="gift-preview-wrapper" style="margin-top: 1rem; padding: 0 1rem 1rem;">
        <button type="button" id="gift-preview-btn" class="gift-preview-btn">
          👁️ Preview Gift Message
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Gift Preview Modal -->

<!-- Gift Preview Modal -->
<div id="gift-preview-modal" class="gift-modal" role="dialog" aria-modal="true" aria-labelledby="gift-preview-title" style="display: none; z-index: 999;">
  <div class="gift-modal-overlay"></div>
  <div class="gift-modal-container">
    <div class="gift-modal-header">
      <h3 id="gift-preview-title">Gift Configuration Preview</h3>
      <button type="button" class="gift-modal-close" id="gift-modal-close" aria-label="Close Preview">&times;</button>
    </div>
    <div class="gift-modal-body" id="gift-preview-body">
      <!-- JavaScript will populate this -->
    </div>
    <div class="gift-modal-footer">
      <button type="button" class="gift-btn-secondary" id="gift-modal-edit">Edit Details</button>
      <button type="button" class="gift-btn-primary" id="gift-modal-confirm">Looks Good</button>
    </div>
  </div>
</div>

<!-- Gift Progress Modal -->
<div id="gift-progress-modal" class="gift-modal" role="dialog" aria-modal="true" aria-labelledby="gift-progress-title" style="display: none; z-index: 10000;">
  <div class="gift-modal-overlay"></div>
  <div class="gift-modal-container gift-progress-container">
    <h3 id="gift-progress-title">Processing Gift...</h3>
    <div class="gift-progress-bar-wrapper">
      <div id="gift-upload-progress" class="gift-progress-bar" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100" style="width: 0%"></div>
    </div>
    <div id="gift-progress-text" aria-live="polite">Initializing...</div>
  </div>
</div>

<!-- Load the JS asset -->
<script src="{{ 'gift-widget.js' | asset_url }}?v=71" defer="defer"></script>

{% style %}
  /* Scoped styles mimicking Tailwind */
  .gift-widget-container {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    margin: 1rem 0;
    width: 100%;
    max-width: 400px;
  }

  .gift-widget-card {
    border: 1px solid #e5e7eb;
    border-radius: 0.5rem;
    background-color: #ffffff;
    box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
    overflow: hidden;
  }

  /* Header */
  .gift-widget-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1rem;
    background-color: #f9fafb;
    border-bottom: 1px solid #e5e7eb;
  }

  .gift-widget-title-group {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 500;
    color: #111827;
    font-size: 0.875rem;
  }
  
  .gift-icon { font-size: 1.1em; }

  /* Toggle Switch */
  .gift-toggle-switch {
    position: relative;
    display: inline-block;
    width: 44px;
    height: 24px;
  }
  .gift-toggle-switch input { opacity: 0; width: 0; height: 0; }
  .gift-slider {
    position: absolute;
    cursor: pointer;
    top: 0; left: 0; right: 0; bottom: 0;
    background-color: #e5e7eb;
    -webkit-transition: .4s;
    transition: .4s;
    border-radius: 34px;
  }
  .gift-slider:before {
    position: absolute;
    content: "";
    height: 20px;
    width: 20px;
    left: 2px;
    bottom: 2px;
    background-color: white;
    -webkit-transition: .4s;
    transition: .4s;
    border-radius: 50%;
    box-shadow: 0 1px 2px rgba(0,0,0,0.2);
  }
  input:checked + .gift-slider { background-color: #10b981; }
  input:focus + .gift-slider { box-shadow: 0 0 1px #10b981; }
  input:checked + .gift-slider:before {
    -webkit-transform: translateX(20px);
    -ms-transform: translateX(20px);
    transform: translateX(20px);
  }

  /* Content Area */
  .gift-options-content {
    padding: 1rem;
    transition: all 0.3s ease;
  }

  /* Tabs */
  .gift-tabs {
    display: flex;
    background-color: #f3f4f6;
    padding: 0.25rem;
    border-radius: 0.375rem;
    margin-bottom: 1rem;
  }
  .gift-tab {
    flex: 1;
    padding: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: #4b5563;
    background: transparent;
    border: none;
    border-radius: 0.25rem;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
  }
  .gift-tab.active {
    background-color: #ffffff;
    color: #111827;
    box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
  }

  /* Digital Format Buttons */
  .gift-format-label {
    font-size: 0.75rem;
    color: #6b7280;
    margin-bottom: 0.5rem;
  }
  .gift-format-buttons {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }
  .format-btn {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    padding: 0.375rem 0.5rem;
    background-color: #f3f4f6;
    border: 1px solid transparent;
    border-radius: 0.375rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: #374151;
    cursor: pointer;
    white-space: nowrap;
  }
  .format-btn:hover { background-color: #e5e7eb; }
  .format-btn.active {
    background-color: #1f2937;
    color: #ffffff;
    border-color: #1f2937;
  }

  /* Action Button (Record Video) */
  .action-btn {
    width: 100%;
    padding: 0.75rem;
    background-color: #1f2937;
    color: white;
    font-weight: 600;
    font-size: 0.875rem;
    border: none;
    border-radius: 0.375rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    transition: background-color 0.2s;
  }
  .action-btn:hover { background-color: #111827; }
  .record-icon { color: #ef4444; }

  /* Textarea */
  .gift-textarea {
    width: 100%;
    padding: 0.5rem;
    border: 1px solid #d1d5db;
    border-radius: 0.375rem;
    font-size: 0.875rem;
    min-height: 80px;
    resize: vertical;
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  /* Total Row */
  .gift-total-row {
    font-weight: 600;
    margin-bottom: 0.75rem;
    text-align: right;
    color: #111827;
  }
  .gift-total-amount {
    color: #059669; /* Green-600 */
  }

  /* Preview Button */
  .gift-preview-btn {
    width: 100%;
    padding: 0.5rem;
    background-color: #f3f4f6;
    color: #4b5563;
    font-weight: 500;
    font-size: 0.875rem;
    border: 1px solid #d1d5db;
    border-radius: 0.375rem;
    cursor: pointer;
    transition: all 0.2s;
    text-align: center;
  }
  .gift-preview-btn:hover {
    background-color: #e5e7eb;
    color: #111827;
  }

  /* Modal Styles */
  .gift-modal {
    position: fixed;
    z-index: 9999;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    overflow: auto;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .gift-modal-overlay {
    position: absolute;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(2px);
  }
  .gift-modal-container {
    background-color: #fff;
    margin: 1rem;
    padding: 0;
    border-radius: 0.75rem;
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
    width: 100%;
    max-width: 500px;
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    max-height: 90vh;
  }
  .gift-modal-header {
    padding: 1rem 1.5rem;
    border-bottom: 1px solid #e5e7eb;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .gift-modal-header h3 {
    margin: 0;
    font-size: 1.125rem;
    font-weight: 600;
    color: #111827;
  }
  .gift-modal-close {
    background: transparent;
    border: none;
    font-size: 1.5rem;
    line-height: 1;
    color: #9ca3af;
    cursor: pointer;
    padding: 0.25rem;
  }
  .gift-modal-close:hover {
    color: #4b5563;
  }
  .gift-modal-body {
    padding: 1.5rem;
    overflow-y: auto;
    flex: 1;
  }
  .gift-preview-row {
    margin-bottom: 1rem;
    border-bottom: 1px solid #f3f4f6;
    padding-bottom: 1rem;
  }
  .gift-preview-row:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }
  .gift-preview-label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    color: #6b7280;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.25rem;
  }
  .gift-preview-value {
    font-size: 0.95rem;
    color: #111827;
    word-break: break-word;
  }
  .gift-preview-media {
    max-width: 100%;
    max-height: 200px;
    border-radius: 0.5rem;
    border: 1px solid #e5e7eb;
    margin-top: 0.5rem;
    object-fit: contain;
  }
  .gift-modal-footer {
    padding: 1rem 1.5rem;
    background-color: #f9fafb;
    border-top: 1px solid #e5e7eb;
    display: flex;
    justify-content: flex-end;
    gap: 0.75rem;
    border-bottom-left-radius: 0.75rem;
    border-bottom-right-radius: 0.75rem;
  }
  .gift-btn-secondary {
    padding: 0.5rem 1rem;
    background-color: #fff;
    border: 1px solid #d1d5db;
    border-radius: 0.375rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: #374151;
    cursor: pointer;
  }
  .gift-btn-secondary:hover {
    background-color: #f3f4f6;
  }
  .gift-btn-primary {
    padding: 0.5rem 1rem;
    background-color: #111827;
    border: 1px solid transparent;
    border-radius: 0.375rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: white;
    cursor: pointer;
  }
  .gift-btn-primary:hover {
    background-color: #000;
  }


  /* New Inputs */
  .gift-text-input {
    width: 100%;
    padding: 0.5rem;
    border: 1px solid #d1d5db;
    border-radius: 0.375rem;
    font-size: 0.875rem;
  }
  .gift-file-input {
    width: 100%;
    font-size: 0.875rem;
    color: #4b5563;
  }
  .gift-input-label {
    display: block;
    font-size: 0.75rem;
    color: #374151;
    margin-bottom: 0.25rem;
    font-weight: 500;
  }

  .gift-char-count {
    text-align: right;
    font-size: 0.75rem;
    color: #6b7280;
    margin-top: 0.25rem;
    font-family: inherit;
  }
  .gift-file-feedback {
    display: block;
    font-size: 0.85rem;
    margin-top: 0.5rem;
    color: #4b5563;
  }
  .gift-file-feedback.error {
    color: #ef4444;
  }
  .gift-file-feedback.success {
    color: #10b981;
  }
  
  /* Progress Modal Styles */
  .gift-progress-container {
    text-align: center;
    padding: 2rem;
    max-width: 400px;
  }
  #gift-progress-title {
    margin-bottom: 1rem;
    font-size: 1.1rem;
    font-weight: 600;
  }
  .gift-progress-bar-wrapper {
    width: 100%;
    height: 10px;
    background-color: #e5e7eb;
    border-radius: 5px;
    overflow: hidden;
    margin-bottom: 0.5rem;
  }
  .gift-progress-bar {
    height: 100%;
    background-color: #3b82f6;
    transition: width 0.2s ease;
  }
  #gift-progress-text {
    font-size: 0.9rem;
    color: #4b5563;
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
{% endstyle %}

<script>
// Call Vercel directly — bypasses Shopify App Proxy which changes URL on every dev session
window.GIFT_WIDGET_API_BASE = 'https://empowered-deal-app.vercel.app/api';
window.GIFT_WIDGET_UPLOAD_URL = 'https://empowered-deal-app.vercel.app/api/generate-qr';
</script>

{% schema %}
{
  "name": "Gift Options Widget",
  "target": "section",
  "settings": [
      {
        "type": "checkbox",
        "id": "enable_digital",
        "label": "Enable Digital Gifts",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "enable_printed",
        "label": "Enable Printed Gifts",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "enable_message",
        "label": "Enable Custom Message",
        "default": true
      },
      {
        "type": "text",
        "id": "custom_message_label",
        "label": "Custom Message Label",
        "default": "Add custom message"
      },
      {
        "type": "checkbox",
        "id": "enable_caption",
        "label": "Enable Caption Input",
        "default": true
      },
      {
        "type": "text",
        "id": "caption_label",
        "label": "Caption Label",
        "default": "Caption"
      },
      {
        "type": "text",
        "id": "caption_placeholder",
        "label": "Caption Placeholder",
        "default": "Short message..."
      }
  ]
}
{% endschema %}
